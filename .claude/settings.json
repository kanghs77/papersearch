
{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/install_pkgs.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(pdftotext *)",
      "Bash(python3 *)",
      "Bash(uv *)",
      "Bash(mkdir *)",
      "WebFetch",
      "WebSearch"
    ]
  }
}
